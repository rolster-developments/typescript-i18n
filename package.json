{
  "name": "@rolster/i18n",
  "version": "3.1.3",
  "type": "module",
  "description": "Utility lightweight simple translation.",
  "license": "MIT",
  "author": "Rolster Technology <rolster.developments@gmail.com>",
  "contributors": [
    {
      "name": "Daniel Andrés Castillo Pedroza",
      "email": "ing.dacastillop@gmail.com"
    }
  ],
  "types": "./dist/esm/index.d.ts",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/es/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "node": {
        "require": "./dist/cjs/index.cjs",
        "import": "./dist/es/index.mjs"
      },
      "default": "./dist/es/index.mjs"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "prettier": "prettier --write \"src/*.{ts}\"",
    "clean": "rimraf ./dist",
    "build": "npm run clean && tsc -p tsconfig.app.json && rollup -c rollup.config.mjs",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@rolster/strings": "^3.1.1"
  },
  "devDependencies": {
    "@rolster/rollup": "^2.1.1",
    "@rolster/types": "^1.1.1",
    "@vitest/ui": "^4.1.8",
    "jsdom": "^27.0.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tslib": "^2.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rolster-developments/typescript-i18n.git"
  },
  "keywords": [
    "rolster",
    "typescript",
    "i18n"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  }
}
